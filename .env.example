# Copy to `.env.local`. Restart `npm run dev` after edits.

# Public site origin (no trailing slash). Used at build time for og:image / Twitter absolute URLs.
# On Netlify you can omit this if `URL` is set in the build environment (injected automatically).
# Example: https://sr-originals.netlify.app or your custom domain.
VITE_SITE_URL=

# Production key (also used locally if LOCAL is not set). On Netlify, set this only — not LOCAL.
VITE_GOOGLE_DRIVE_API_KEY=

# Local dev only: second key restricted to http://localhost:5173/* so Netlify key stays Netlify-only.
# If set, `npm run dev` uses this for Drive list + images instead of VITE_GOOGLE_DRIVE_API_KEY.
VITE_GOOGLE_DRIVE_API_KEY_LOCAL=

VITE_GOOGLE_DRIVE_FOLDER_ID=

# Optional: Bump Era masonry on Home (`/`). If unset, uses `driveFolderId` in mediaConfig when present.
# Sprinkle Season page (`/sprinkle-season`, baby shower photos). Uses only this var — not `VITE_GOOGLE_DRIVE_FOLDER_ID`.
# (Env name kept as BABY_SHOWER for existing Netlify configs; `/baby-shower` redirects to `/sprinkle-season`.)
VITE_GOOGLE_DRIVE_FOLDER_ID_BABY_SHOWER=
