# Copy to `.env.local` (gitignored) and fill in. Restart `npm run dev` after changes.

# Drive masonry: set both in `.env.local` (dev) and Netlify site env (production). Do not commit real values.
# Key: Google Cloud Console → APIs & Services → Credentials → API key → enable Google Drive API.
VITE_GOOGLE_DRIVE_API_KEY=

# Folder id from the URL: https://drive.google.com/drive/folders/FOLDER_ID
VITE_GOOGLE_DRIVE_FOLDER_ID=
