# Copy to `.env.local` (gitignored) and fill in. Restart `npm run dev` after changes.

# Required to auto-load a shared folder’s images in the masonry gallery (see mediaConfig `driveFolderId`).
# Get a key: Google Cloud Console → APIs & Services → Credentials → Create API key → enable Drive API.
VITE_GOOGLE_DRIVE_API_KEY=

# Optional: overrides `driveFolderId` in mediaConfig if you prefer env-only config.
# Folder id is the segment in: https://drive.google.com/drive/folders/FOLDER_ID
VITE_GOOGLE_DRIVE_FOLDER_ID=
