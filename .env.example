# Copy to `.env.local`. Restart `npm run dev` after edits.

# Production key (also used locally if LOCAL is not set). On Netlify, set this only — not LOCAL.
VITE_GOOGLE_DRIVE_API_KEY=

# Local dev only: second key restricted to http://localhost:5173/* so Netlify key stays Netlify-only.
# If set, `npm run dev` uses this for Drive list + images instead of VITE_GOOGLE_DRIVE_API_KEY.
VITE_GOOGLE_DRIVE_API_KEY_LOCAL=

VITE_GOOGLE_DRIVE_FOLDER_ID=
